# ContextForge — Configurazione Variabili d'Ambiente

# Provider LLM di default ('ollama', 'deepseek', o 'null' per la modalità offline)
CONTEXTFORGE_PROVIDER=null

# --- Configurazione Ollama (Local LLM) ---
# URL del server Ollama (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434
# Modello Ollama da utilizzare (default: llama3)
OLLAMA_MODEL=llama3

# --- Configurazione DeepSeek (Cloud LLM) ---
# La tua API Key di DeepSeek (necessaria se si usa il provider deepseek)
DEEPSEEK_API_KEY=your_api_key_here
# Modello DeepSeek da utilizzare (default: deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat
